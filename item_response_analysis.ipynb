{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# EpistemicTrap — Item Response Analysis\n",
        "\n",
        "This notebook analyzes per-item performance (when item identifiers are present in exported `*.run.json` logs) and checks that difficulty labels produce a usable gradient.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import glob\n",
        "import json\n",
        "import os\n",
        "from collections import Counter, defaultdict\n",
        "\n",
        "with open('metacog_dataset.json', 'r', encoding='utf-8') as f:\n",
        "    main = json.load(f)\n",
        "\n",
        "with open('pressure_scenarios.json', 'r', encoding='utf-8') as f:\n",
        "    pressure = json.load(f)\n",
        "\n",
        "by_id = {x['id']: x for x in main}\n",
        "by_id.update({x['id']: x for x in pressure})\n",
        "\n",
        "print('Main items:', len(main))\n",
        "print('Pressure items:', len(pressure))\n",
        "print('Main difficulty distribution:', dict(Counter([(x.get('subtype'), x.get('difficulty')) for x in main])))\n",
        "print('Pressure type distribution:', dict(Counter([x.get('type') for x in pressure])))\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def find_run_logs():\n",
        "    paths = set()\n",
        "    for pat in ['*.run.json', '**/*.run.json']:\n",
        "        for p in glob.glob(pat, recursive=True):\n",
        "            if os.path.isfile(p):\n",
        "                paths.add(p)\n",
        "    return sorted(paths)\n",
        "\n",
        "def get_item_id_from_conversation(c: dict):\n",
        "    for k in ['evaluationDataId', 'evaluation_data_id', 'exampleId', 'example_id', 'inputId', 'input_id', 'id']:\n",
        "        v = c.get(k)\n",
        "        if isinstance(v, str) and v:\n",
        "            return v\n",
        "    ex = c.get('example')\n",
        "    if isinstance(ex, dict):\n",
        "        v = ex.get('id')\n",
        "        if isinstance(v, str) and v:\n",
        "            return v\n",
    \n",
        "    return None\n",
        "\n",
        "def get_numeric_result(c: dict):\n",
        "    r = (c.get('result') or {})\n",
        "    numeric = (r.get('numericResult') or {})\n",
        "    val = numeric.get('value')\n",
        "    if val is None:\n",
        "        return None\n",
        "    try:\n",
        "        return float(val)\n",
        "    except Exception:\n",
        "        return None\n",
        "\n",
        "paths = find_run_logs()\n",
        "print('Found run logs:', len(paths))\n",
        "paths[:10]\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "item_scores = defaultdict(list)\n",
        "unmapped = 0\n",
        "\n",
        "for p in paths:\n",
        "    with open(p, 'r', encoding='utf-8') as f:\n",
        "        run = json.load(f)\n",
        "    for c in run.get('conversations', []) or []:\n",
        "        item_id = get_item_id_from_conversation(c)\n",
        "        val = get_numeric_result(c)\n",
        "        if val is None:\n",
        "            continue\n",
        "        if not item_id or item_id not in by_id:\n",
        "            unmapped += 1\n",
        "            continue\n",
        "        item_scores[item_id].append(val)\n",
        "\n",
        "print('Items with scores:', len(item_scores))\n",
        "print('Unmapped conversations with numericResult:', unmapped)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def mean(xs):\n",
        "    return sum(xs) / len(xs)\n",
        "\n",
        "by_bucket = defaultdict(list)\n",
        "for item_id, vals in item_scores.items():\n",
        "    meta = by_id[item_id]\n",
        "    subtype = meta.get('subtype') or 'PRESSURE'\n",
        "    difficulty = meta.get('difficulty') or meta.get('type')\n",
        "    by_bucket[(subtype, difficulty)].append(mean(vals))\n",
        "\n",
        "rows = []\n",
        "for (subtype, difficulty), xs in sorted(by_bucket.items()):\n",
        "    rows.append((subtype, str(difficulty), len(xs), f\"{mean(xs):.3f}\"))\n",
        "\n",
        "rows\n"
      ]
    }
  ],
